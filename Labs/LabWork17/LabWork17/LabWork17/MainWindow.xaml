<Window x:Class="LabWork17.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LabWork17"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл"/>
            <MenuItem Header="Правка"/>
            <MenuItem Header="Вид"/>
            <MenuItem Header="Справка"/>
        </Menu>

        <StackPanel DockPanel.Dock="Top" Margin="5">
            <TextBlock Text="Имя каталога" Margin="2"/>
            <TextBox Text="{Binding SearchString, UpdateSourceTrigger=PropertyChanged}" Margin="2"/>
            <Button Content="Вывести все вложенные файлы" Command="{Binding SearchCommand}" CommandParameter="{Binding SearchString}" Margin="2"/>
        </StackPanel>

        <Grid Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Иконка файла:" Grid.Column="0" Grid.Row="0" Margin="5"/>
            <TextBlock Text="Имя файла:" Grid.Column="1" Grid.Row="0" Margin="5"/>
            <TextBlock Text="Дата изменения:" Grid.Column="2" Grid.Row="0" Margin="5"/>
            <TextBlock Text="Размер файла:" Grid.Column="3" Grid.Row="0" Margin="5"/>

            <ScrollViewer Grid.Row="1" Grid.ColumnSpan="4" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Files}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Icon}" Grid.Column="0" Margin="5"/>
                                <TextBlock Text="{Binding Name}" Grid.Column="1" Margin="5"/>
                                <TextBlock Text="{Binding ModifiedDate}" Grid.Column="2" Margin="5"/>
                                <TextBlock Text="{Binding Size}" Grid.Column="3" Margin="5"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>