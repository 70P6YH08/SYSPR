<Window x:Class="LabWork20.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LabWork20"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel>
        <Menu>
            <MenuItem Header="Запустить новую задачу"/>
            <MenuItem Header="Снять задачу"/>
            <MenuItem Header="Выход"/>
        </Menu>
        <TabControl Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type Window}}, Path=ActualHeight}"
                    MaxWidth="1200">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Процессы ("/>
                        <TextBlock Text="{Binding CountProcess}"/>
                        <TextBlock Text=")"/>
                    </StackPanel>
                </TabItem.Header>
                    <ListView ItemsSource="{Binding Processes}" Margin="3" ScrollViewer.VerticalScrollBarVisibility="Visible">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn DisplayMemberBinding="{Binding Path=Id}" Width="100" Header="Id"/>
                                <GridViewColumn DisplayMemberBinding="{Binding Path=ProcessName}" Width="200" Header="Имя"/>
                                <GridViewColumn DisplayMemberBinding="{Binding Path=WorkingSet64}" Width="200" Header="Память"/>
                            </GridView>
                        </ListView.View>
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Снять задачу"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                </ListView>
            </TabItem>
            <TabItem Header="Приложения">
                <ListView ItemsSource="{Binding Applications}" Margin="3" ScrollViewer.VerticalScrollBarVisibility="Visible">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=MainWindowTitle}" Width="200" Header="Приложение"/>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=StartTime, StringFormat='dd/MM/yyyy hh:mm:ss'}" Width="200" Header="Время запуска"/>
                        </GridView>
                    </ListView.View>
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Снять задачу"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                </ListView>
            </TabItem>
        </TabControl>
    </StackPanel>
</Window>
